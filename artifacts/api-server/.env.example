# Clerk keys for the API server.
# Get them from Clerk Dashboard -> API keys.
PORT=3001
CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Optional: the mobile build script uses this to construct EXPO_PUBLIC_CLERK_PROXY_URL.
CLERK_PROXY_URL=/api/__clerk

# Other server-side keys used by API routes.
OPENAI_API_KEY=
