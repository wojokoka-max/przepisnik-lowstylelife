# Production API server variables.
# Do not commit real secrets in .env files.

# Hosting providers usually inject PORT automatically.
PORT=3001

# Clerk production keys for the mobile app backend/proxy.
CLERK_PUBLISHABLE_KEY=pk_live_replace_me
CLERK_SECRET_KEY=sk_live_replace_me
CLERK_PROXY_URL=/api/__clerk

# OpenAI key used only by the backend. Never put this in the mobile app.
OPENAI_API_KEY=sk-proj_replace_me
