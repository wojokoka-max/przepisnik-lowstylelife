{
  "expo": {
    "name": "Przepiśnik. Inteligentny organizer kulinarny",
    "slug": "przepisnik-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-lsl.jpg",
    "scheme": "przepisnik",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo-lsl.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#07111f"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.lowstylelife.przepisnik",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-lsl.png",
        "backgroundColor": "#07111f"
      }
    },
    "web": {
      "favicon": "./assets/images/logo-lsl.jpg"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
