# Production mobile variables for EAS/Google Play builds.
# These values are safe to expose only if they start with EXPO_PUBLIC_.

# Clerk production publishable key for the Expo app.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_replace_me

# Public HTTPS URL of the deployed API server.
# Example: https://przepisnik-api.example.com/api
EXPO_PUBLIC_API_BASE_URL=https://replace-with-public-api-domain.example.com/api

# Optional Clerk proxy URL, if auth should go through the backend proxy.
# Example: https://przepisnik-api.example.com/api/__clerk
EXPO_PUBLIC_CLERK_PROXY_URL=

# GitHub username allowed to enter admin mode.
EXPO_PUBLIC_ADMIN_GITHUB_USERNAME=wojokoka-max
