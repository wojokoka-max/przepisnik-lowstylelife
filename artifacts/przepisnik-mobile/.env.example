# Clerk public key for the mobile Expo app.
# Get it from Clerk Dashboard -> API keys -> Publishable key.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# API/backend domain used by the generated API client.
# Example: lowstylelife-przepisnik-api.example.com
EXPO_PUBLIC_DOMAIN=

# Full API base URL for local/native testing or production builds.
# Local Android/Expo example: http://192.168.1.20:3001/api
# Production example: https://lowstylelife-przepisnik-api.example.com/api
EXPO_PUBLIC_API_BASE_URL=

# Optional Clerk proxy URL when using the API server proxy.
# Example: https://your-api-domain.com/api/__clerk
EXPO_PUBLIC_CLERK_PROXY_URL=

# GitHub username allowed to enter admin mode.
EXPO_PUBLIC_ADMIN_GITHUB_USERNAME=wojokoka-max
